# Copy to .env and fill in real values. Never commit .env.
# chmod 600 .env

APP_VERSION=0.1.0

# Server-rol — alleen SELECT
NEVO_API_URL=postgresql://nutrientcontent_api:CHANGE_ME@127.0.0.1:5432/nutrientcontent_db

# Loader-rol — DDL + writes (alleen lokaal gebruiken, niet in server-process)
NEVO_LOADER_URL=postgresql://nutrientcontent_loader:CHANGE_ME@127.0.0.1:5432/nutrientcontent_db

# 32 random bytes hex — genereer met:  openssl rand -hex 32
API_KEY=CHANGE_ME

# logging: debug | info | warning | error
LOG_LEVEL=info
